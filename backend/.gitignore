```gitignore
# -----------------------------
# Node.js / Frontend
# -----------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

.next/
out/
dist/
build/
coverage/
.cache/
.parcel-cache/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs
*.log

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# -----------------------------
# Python / Backend
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
env/
ENV/
.venv/

# Python build files
build/
dist/
*.egg-info/
.eggs/

# Testing / Coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/

# Jupyter
.ipynb_checkpoints/

# FastAPI / Flask / Django
*.sqlite3
instance/
media/

# -----------------------------
# Docker
# -----------------------------
docker-compose.override.yml

# -----------------------------
# Misc
# -----------------------------
tmp/
temp/
*.pid
*.seed
```
